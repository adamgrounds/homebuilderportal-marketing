---
---

<footer class="bg-primary text-white">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-1">
        <img
          src="/logo.png"
          alt="Home Builder Portal"
          width="160"
          height="40"
          class="h-10 w-auto mb-4"
        />
        <p class="text-white/60 text-sm leading-relaxed max-w-xs">
          Keep your homebuyers informed and excited throughout construction — without adding work
          to your team.
        </p>
      </div>

      <!-- Pages -->
      <div>
        <h4 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Pages</h4>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a href="/" class="text-white/65 hover:text-white transition-colors">Home</a>
          </li>
          <li>
            <a href="/features" class="text-white/65 hover:text-white transition-colors"
              >Features</a
            >
          </li>
          <li>
            <a href="/demo" class="text-white/65 hover:text-white transition-colors">Book a Demo</a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-xs font-semibold text-white/40 uppercase tracking-widest mb-4">Legal</h4>
        <ul class="flex flex-col gap-3 text-sm">
          <li>
            <a href="/privacy-policy" class="text-white/65 hover:text-white transition-colors"
              >Privacy Policy</a
            >
          </li>
          <li>
            <a href="/terms-of-service" class="text-white/65 hover:text-white transition-colors"
              >Terms of Service</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-white/10">
      <p class="text-white/35 text-sm text-center">
        © 2026 Home Builder Portal. All rights reserved.
      </p>
    </div>
  </div>
</footer>
