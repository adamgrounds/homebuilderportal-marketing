---
interface Props {
  number: number;
  title: string;
  description: string;
}

const { number, title, description } = Astro.props;
---

<div class="flex gap-6 items-start">
  <div
    class="flex-shrink-0 w-12 h-12 bg-accent rounded-full flex items-center justify-center text-white font-bold text-xl shadow-sm"
    aria-hidden="true"
  >
    {number}
  </div>
  <div class="pt-1">
    <h3 class="font-heading font-bold text-lg text-primary mb-2">{title}</h3>
    <p class="text-gray-600 leading-relaxed">{description}</p>
  </div>
</div>
