---
---

<form
  action="https://api.web3forms.com/submit"
  method="POST"
  class="bg-white rounded-2xl shadow-xl p-8 md:p-10"
  id="demo-form"
>
  <!-- Web3Forms required fields -->
  <input type="hidden" name="access_key" value="ea52a98a-76ca-4e19-9690-2a91898e039e" />
  <input
    type="hidden"
    name="redirect"
    value="https://www.homebuilderportal.com/thank-you"
  />
  <input type="hidden" name="subject" value="New Demo Request — Home Builder Portal" />

  <!-- Honeypot (spam prevention) -->
  <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" />

  <!-- Name row -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
    <div>
      <label for="first_name" class="block text-sm font-semibold text-gray-700 mb-1.5">
        First Name <span class="text-accent">*</span>
      </label>
      <input
        type="text"
        id="first_name"
        name="first_name"
        required
        placeholder="Jane"
        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
      />
    </div>
    <div>
      <label for="last_name" class="block text-sm font-semibold text-gray-700 mb-1.5">
        Last Name <span class="text-accent">*</span>
      </label>
      <input
        type="text"
        id="last_name"
        name="last_name"
        required
        placeholder="Smith"
        class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
      />
    </div>
  </div>

  <!-- Company -->
  <div class="mb-5">
    <label for="company" class="block text-sm font-semibold text-gray-700 mb-1.5">
      Company Name <span class="text-accent">*</span>
    </label>
    <input
      type="text"
      id="company"
      name="company"
      required
      placeholder="Smith Family Homes"
      class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
    />
  </div>

  <!-- Email -->
  <div class="mb-5">
    <label for="email" class="block text-sm font-semibold text-gray-700 mb-1.5">
      Work Email <span class="text-accent">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="jane@smithhomes.com"
      class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
    />
  </div>

  <!-- Phone -->
  <div class="mb-5">
    <label for="phone" class="block text-sm font-semibold text-gray-700 mb-1.5">
      Phone <span class="text-gray-400 font-normal">(optional)</span>
    </label>
    <input
      type="tel"
      id="phone"
      name="phone"
      placeholder="(555) 123-4567"
      class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition"
    />
  </div>

  <!-- Homes per year -->
  <div class="mb-8">
    <label for="homes_per_year" class="block text-sm font-semibold text-gray-700 mb-1.5">
      Homes Built Per Year <span class="text-accent">*</span>
    </label>
    <select
      id="homes_per_year"
      name="homes_per_year"
      required
      class="w-full border border-gray-300 rounded-lg px-4 py-3 text-gray-900 focus:outline-none focus:ring-2 focus:ring-accent focus:border-transparent transition bg-white"
    >
      <option value="" disabled selected>Select a range</option>
      <option value="Less than 25">Less than 25</option>
      <option value="25-100">25 – 100</option>
      <option value="101-250">101 – 250</option>
      <option value="251-500">251 – 500</option>
      <option value="500+">500+</option>
    </select>
  </div>

  <button
    type="submit"
    class="w-full bg-accent text-white py-4 px-8 rounded-lg font-bold text-lg hover:bg-orange-600 transition-colors cursor-pointer"
  >
    Book Your Demo →
  </button>

  <p class="text-center text-sm text-gray-400 mt-4">No commitment required. 30 minutes. Free.</p>
</form>
