---
import BaseLayout from '../layouts/BaseLayout.astro';
import DemoForm from '../components/DemoForm.astro';
---

<BaseLayout
  title="Book a Demo — Home Builder Portal"
  description="See Home Builder Portal in action. Book a free 30-minute demo and discover how to turn construction updates into 5-star reviews and referrals for your team."
>
  <section class="min-h-screen py-20 px-6 bg-gray-50">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <!-- Left: Copy -->
        <div class="lg:pt-4">
          <p class="text-accent font-semibold text-sm uppercase tracking-wider mb-3">
            Free 30-Minute Walkthrough
          </p>
          <h1 class="font-heading text-4xl md:text-5xl font-bold text-primary mb-5 leading-tight">
            See Home Builder Portal in Action
          </h1>
          <p class="text-gray-600 text-lg leading-relaxed mb-8">
            We'll walk you through the full platform — both the team experience and what your
            buyers would actually see. No slides. No sales pitch. Just the live product.
          </p>

          <ul class="flex flex-col gap-4 text-gray-700">
            {
              [
                'See exactly how your team would post a field update in under a minute',
                "Walk through the buyer experience — what they see, when they see it",
                'Learn how templates keep communication consistent across your team',
                'Ask any questions about implementation, setup, and fit',
              ].map((item) => (
                <li class="flex items-start gap-3">
                  <span class="text-accent font-bold flex-shrink-0 mt-0.5">✓</span>
                  <span class="text-sm">{item}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <!-- Right: Form -->
        <div>
          <DemoForm />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
